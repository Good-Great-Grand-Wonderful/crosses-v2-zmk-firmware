/dts-v1/;
#include <nordic/nrf52840_qiaa.dtsi>
#include <common/nordic/nrf52840_uf2_boot_mode.dtsi>

#include <dt-bindings/zmk/matrix_transform.h>
#include <dt-bindings/zmk/input_transform.h>
#include <input/processors.dtsi>
#include <input/processors/report_rate_limit.dtsi>

#include "crosses_v2_pinctrl.dtsi"

#include "layout_54.dtsi"
#include "layout_42.dtsi"
#include "layout_36.dtsi"

&gggw_crosses_54_layout {
  transform = <&default_transform>;
};

&gggw_crosses_42_layout {
  transform = <&forty_two_transform>;
};

&gggw_crosses_36_layout {
  transform = <&thirty_six_transform>;
};

/ {
    chosen {
      zmk,kscan = &kscan0;
      zmk,physical-layout = &gggw_crosses_54_layout;
      zephyr,code-partition = &code_partition;
      zephyr,sram = &sram0;
      zephyr,flash = &flash0;
      zmk,battery = &vbatt;
    };

    leds {
        compatible = "gpio-leds";
        blue_led: led_0 {
            gpios = <&gpio0 4 GPIO_ACTIVE_HIGH>;
        };
    };

    vbatt: vbatt {
      compatible = "zmk,battery-nrf-vddh";
    };

    default_transform: keymap_transform0 {
      compatible = "zmk,matrix-transform";
      columns = <12>;
      rows = <5>;
      map = <
        RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)       RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10) RC(0,11)
        RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)       RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11)
        RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)       RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11)
        RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)       RC(3,6) RC(3,7) RC(3,8) RC(3,9) RC(3,10) RC(3,11)
                                RC(4,3) RC(4,4) RC(4,5)       RC(4,6) RC(4,7) RC(4,8)
      >;
    };

    forty_two_transform: keymap_transform1 {
      compatible = "zmk,matrix-transform";
      columns = <12>;
      rows = <5>;
      map = <
        RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)       RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11)
        RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)       RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11)
        RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)       RC(3,6) RC(3,7) RC(3,8) RC(3,9) RC(3,10) RC(3,11)
                                RC(4,3) RC(4,4) RC(4,5)       RC(4,6) RC(4,7) RC(4,8)
      >;
    };

    thirty_six_transform: keymap_transform2 {
      compatible = "zmk,matrix-transform";
      columns = <12>;
      rows = <5>;
      map = <
        RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)           RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10)
        RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)           RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10)
        RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)           RC(3,6) RC(3,7) RC(3,8) RC(3,9) RC(3,10)
                        RC(4,3) RC(4,4) RC(4,5)           RC(4,6) RC(4,7) RC(4,8)
      >;
    };

    kscan0: kscan {
      compatible = "zmk,kscan-gpio-matrix";
      wakeup-source;

      debounce-press-ms = <4>;
      debounce-release-ms = <20>;
      diode-direction = "col2row";
    };


    //right hand trackball
    split_inputs {
      #address-cells = <1>;
      #size-cells = <0>;

      trackball_peripheral_split: trackball_peripheral_split@0 {
        compatible = "zmk,input-split";
        reg = <0>;
      };
    };

    trackball_peripheral_listener: trackball_peripheral_listener {
      compatible = "zmk,input-listener";
      status = "disabled";
      device = <&trackball_peripheral_split>;
    };

    //left hand trackball
    trackball_central_listener: trackball_central_listener {
      compatible = "zmk,input-listener";
      status = "disabled";
    };

    // ---- Trackball modes (selectable via the config app / pipe_switch) ----
    //
    // Both balls expose the same 3 modes in the same order, so the app shows
    // an identical menu and the "invert scroll" checkbox just picks between
    // the two Scroll pipelines:
    //   index 0 = Cursor      (pointer movement)
    //   index 1 = Scroll Up   (one wheel direction)
    //   index 2 = Scroll Down (the opposite wheel direction)
    //
    // Per-ball ORIENTATION differs because the sensors are mounted mirrored:
    // the left (peripheral) sensor needs no axis flip, the right (central)
    // one needs X+Y inverted (this matches the cursor behavior the board
    // shipped with). SCROLL DIRECTION is then flipped between Up/Down by an
    // extra Y invert. If Up/Down feel backwards on the bench, just swap the
    // two `label`s; if a whole ball's cursor/scroll axis is wrong, adjust its
    // INPUT_TRANSFORM_* flags. Feel knobs: zip_scroll_scaler (mult/div) and
    // zip_report_rate_limit (ms).
    //
    // Defined here (not in the per-side .dts) because the shared keymap's
    // &pipe_switch reference must resolve on both halves and every
    // sub-processor phandle exists on both.

    // Left (peripheral) ball. Applied on the left half via
    // &trackball_peripheral_split. No orientation flip (matches prior cursor).
    zip_periph_ball: zip_periph_ball {
      compatible = "zmk,input-processor-pipeline-switch";
      #input-processor-cells = <0>;
      persistent;
      default-index = <0>;

      cursor {
        label = "Cursor";
        input-processors = <&zip_report_rate_limit 2>;
      };

      scroll_up {
        label = "Scroll Up";
        input-processors
          = <&zip_xy_to_scroll_mapper>
          , <&zip_scroll_scaler 1 8>
          , <&zip_report_rate_limit 16>;
      };

      scroll_down {
        label = "Scroll Down";
        input-processors
          = <&zip_xy_transform (INPUT_TRANSFORM_Y_INVERT)>
          , <&zip_xy_to_scroll_mapper>
          , <&zip_scroll_scaler 1 8>
          , <&zip_report_rate_limit 16>;
      };
    };

    // Right (central) ball. Runs on the central via trackball_central_listener.
    // Orientation = X+Y invert in every mode (matches prior cursor behavior).
    // Scroll Down reuses orientation with Y un-inverted (net X invert), which
    // is the opposite wheel direction from Scroll Up.
    zip_central_ball: zip_central_ball {
      compatible = "zmk,input-processor-pipeline-switch";
      #input-processor-cells = <0>;
      persistent;
      default-index = <0>;

      cursor {
        label = "Cursor";
        input-processors
          = <&zip_xy_transform (INPUT_TRANSFORM_X_INVERT | INPUT_TRANSFORM_Y_INVERT)>
          , <&zip_report_rate_limit 4>;
      };

      scroll_up {
        label = "Scroll Up";
        input-processors
          = <&zip_xy_transform (INPUT_TRANSFORM_X_INVERT | INPUT_TRANSFORM_Y_INVERT)>
          , <&zip_xy_to_scroll_mapper>
          , <&zip_scroll_scaler 1 8>
          , <&zip_report_rate_limit 16>;
      };

      scroll_down {
        label = "Scroll Down";
        input-processors
          = <&zip_xy_transform (INPUT_TRANSFORM_X_INVERT)>
          , <&zip_xy_to_scroll_mapper>
          , <&zip_scroll_scaler 1 8>
          , <&zip_report_rate_limit 16>;
      };
    };

    behaviors {
      // Node names <= 8 chars: the BLE split relay payload truncates
      // behavior names at 9 bytes (ZMK_SPLIT_RUN_BEHAVIOR_DEV_LEN), and the
      // peripheral looks behaviors up by that name. Labels are not relayed
      // and can stay long. EVENT_SOURCE locality: bind on the left half,
      // where the peripheral split pipelines run.
      // param1 = pipeline index (0 = Cursor, 1 = Scroll Up, 2 = Scroll Down),
      // param2 = persist (0 = live preview, 1 = save to flash). Drives the
      // left/peripheral ball's zip_periph_ball; the central relays to the
      // peripheral by invoking this with event.source = the peripheral index.
      pipe_switch: pswitch {
        compatible = "zmk,behavior-pipeline-switch";
        #binding-cells = <2>;
        processor = <&zip_periph_ball>;
        display-name = "Ball Mode L";
      };

      // Right (central) ball select behavior. Same 2-cell contract; the
      // central runs it locally (no relay). Node name <= 8 chars (pswitchr).
      pipe_switch_r: pswitchr {
        compatible = "zmk,behavior-pipeline-switch";
        #binding-cells = <2>;
        processor = <&zip_central_ball>;
        display-name = "Ball Mode R";
      };

      // EVENT_SOURCE locality: each behavior runs on the half its key is
      // physically pressed on, targeting that half's local sensor. Both
      // nodes must be enabled on both halves so the central can resolve
      // locality and the peripheral can resolve the relayed name. Node
      // names <= 8 chars (see above). sensor_device is set per side in
      // crosses_v2_left.dts / crosses_v2_right.dts.
      dpi_cycle_left: dpi_cy_l {
        compatible = "zmk,behavior-paw32xx-res-cycle";
        #binding-cells = <1>;
        values = <608 798 988 1216 1596>;
        display-name = "DPI Left";
        persistent;
      };

      dpi_cycle_right: dpi_cy_r {
        compatible = "zmk,behavior-paw32xx-res-cycle";
        #binding-cells = <1>;
        values = <608 798 988 1216 1596>;
        display-name = "DPI Right";
        persistent;
      };

      // Absolute CPI set behaviors driven by the config app (param1 = CPI,
      // param2 = persist). EVENT_SOURCE so the central relays the left one to
      // the peripheral. Node names <= 8 chars (cpisetl/cpisetr). default-cpi
      // matches the sensors' res-cpi so the app shows the true start value.
      // sensor_device is set per side in the left/right .dts.
      cpi_set_l: cpisetl {
        compatible = "zmk,behavior-paw32xx-res-set";
        #binding-cells = <2>;
        default-cpi = <700>;
        persistent;
        // Delay the boot-time re-apply of the saved CPI to the sensor until
        // after early-boot churn (USB enumerate / BLE connect) settles; at
        // load-delay=0 the applied value was not sticking after reset. This is
        // an Apply (SPI register write), not a Save - no extra flash wear.
        load_delay = <1000>;
      };

      cpi_set_r: cpisetr {
        compatible = "zmk,behavior-paw32xx-res-set";
        #binding-cells = <2>;
        default-cpi = <700>;
        persistent;
        load_delay = <1000>;
      };
    };
};

&pinctrl {
    spi0_default: spi0_default {
        group1 {
            psels 
              = <NRF_PSEL(SPIM_SCK, 0, 6)>
              , <NRF_PSEL(SPIM_MOSI, 0, 26)>
              , <NRF_PSEL(SPIM_MISO, 0, 26)>
              ;
        };
    };

    spi0_sleep: spi0_sleep {
        group1 {
            psels 
              = <NRF_PSEL(SPIM_SCK, 0, 6)>
              , <NRF_PSEL(SPIM_MOSI, 0, 26)>
              , <NRF_PSEL(SPIM_MISO, 0, 26)>
              ;
            low-power-enable;
        };
    };
};

&reg1 {
  regulator-initial-mode = <NRF5X_REG_MODE_DCDC>;
};

&adc {
	status = "okay";
};

&gpiote {
    status = "okay";
};

&gpio0 {
	status = "okay";
};

&gpio1 {
	status = "okay";
};

&usbd {
	status = "okay";
};

&spi0 {
  status = "okay";
  compatible = "nordic,nrf-spim";
  pinctrl-0 = <&spi0_default>;
  pinctrl-1 = <&spi0_sleep>;
  pinctrl-names = "default", "sleep";
};

&spi1 {
    compatible = "nordic,nrf-spim";
    pinctrl-0 = <&spi1_default>;
    pinctrl-1 = <&spi1_sleep>;
    pinctrl-names = "default", "sleep";
};

zephyr_udc0: &usbd {
    status = "okay";
};

&flash0 {
	/*
	 * For more information, see:
	 * http://docs.zephyrproject.org/latest/devices/dts/flash_partitions.html
	 */
  partitions {
    compatible = "fixed-partitions";
    #address-cells = <1>;
		#size-cells = <1>;

    sd_partition: partition@0 {
      reg = <0x00000000 0x00026000>;
    };
    code_partition: partition@26000 {
      reg = <0x00026000 0x000c6000>;
    };

    /*
     * The flash starting at 0x000ec000 and ending at
     * 0x000f3fff is reserved for use by the application.
     */

    /*
     * Storage partition will be used by FCB/LittleFS/NVS
     * if enabled.
     */
		storage_partition: partition@ec000 {
			reg = <0x000ec000 0x00008000>;
		};

		boot_partition: partition@f4000 {
			reg = <0x000f4000 0x0000c000>;
		};
  };
};
